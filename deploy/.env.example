# AI Workflow Terminal v0.8 - Environment Configuration
# Copy to .env and fill in values

# Deployment mode: cloud | local
DEPLOY_MODE=cloud

# --- Database ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=aiwt
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=ai_workflow_terminal

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Vector DB (Qdrant) ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# --- Object Storage (MinIO) ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme_in_production
MINIO_BUCKET=ai-workflow

# --- Auth ---
JWT_SECRET_KEY=changeme_generate_a_random_64char_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- LLM Providers ---
# Cloud APIs (set the ones you use)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Self-hosted vLLM (optional backup)
VLLM_BASE_URL=http://192.168.1.23:8001
VLLM_MODEL=qwen3.5-35b-a3b

# Default LLM provider: qwen-cloud | openai | claude | vllm
LLM_DEFAULT_PROVIDER=qwen-cloud

# --- HAL Bridge (optional) ---
HAL_BRIDGE_ENABLED=false
HAL_BRIDGE_WS_PORT=9200

# --- App ---
APP_NAME=AI Workflow Terminal
APP_VERSION=0.8.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
APP_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
